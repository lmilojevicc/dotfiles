{
  "C_Cpp.clang_format_fallbackStyle": "{      BasedOnStyle: LLVM,      UseTab: Always,      IndentWidth: 4,      TabWidth: 4,      BreakBeforeBraces: Attach,      AllowShortIfStatementsOnASingleLine: false,      IndentCaseLabels: false,      ColumnLimit: 0,      AccessModifierOffset: -4  }",
  "C_Cpp.clang_format_style": "",
  "[c]": {
    "editor.defaultFormatter": "ms-vscode.cpptools"
  },
  "[cpp]": {
    "editor.defaultFormatter": "ms-vscode.cpptools"
  },
  "[go]": {
    "editor.defaultFormatter": "golang.go"
  },
  "[java]": {
    "editor.defaultFormatter": "redhat.java"
  },
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.wordWrap": "wordWrapColumn"
  },
  "[python]": {
    "editor.codeActionsOnSave": {
      "source.organizeImports": "always"
    },
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.formatOnSave": true
  },
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer"
  },
  "[xml]": {
    "editor.defaultFormatter": "redhat.vscode-xml"
  },
  "animations.Enabled": true,
  "animations.Install-Method": "Custom CSS and JS",
  "breadcrumbs.filePath": "on",
  "breadcrumbs.symbolPath": "off",
  "cSpell.enabled": false,
  "cmake.configureOnOpen": true,
  "cmake.options.statusBarVisibility": "icon",
  "cmake.pinnedCommands": [
    "cmake.debugTarget",
    "cmake.scanForKits",
    "cmake.selectKit",
    "cmake.launchTarget",
    "cmake.build",
    "workbench.action.tasks.configureTaskRunner",
    "workbench.action.tasks.runTask"
  ],
  "codesnap.backgroundColor": "#859ffa",
  "codesnap.containerPadding": "5em",
  "codesnap.target": "window",
  "console-ninja.featureSet": "Community",
  "console-ninja.fontSize": 12,
  "console-ninja.outputMode": "In View",
  "console-ninja.toolsToEnableSupportAutomaticallyFor": {
    "live-preview-extension": true,
    "live-server-extension": true
  },

  /** ------------ Editor Settings ------------ **/
  "editor.accessibilitySupport": "off",
  "editor.cursorBlinking": "expand",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.cursorStyle": "line-thin",
  "editor.cursorSurroundingLines": 20,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.folding": true,
  "editor.fontFamily": "'Consolas For Powerline', 'Sometype Mono', 'Geist Mono', 'Hasklig', 'Hasklug Nerd Font', 'DM Mono', 'SpaceMono Nerd Font', 'FiraCode Nerd Font', 'JetBrainsMono Nerd Font', 'Cascadia Mono NF', 'RecMonoDuotone Nerd Font Mono', monospace",
  "editor.fontLigatures": false,
  "editor.fontSize": 16,
  "editor.fontWeight": 400,
  "editor.formatOnSave": true,
  "editor.glyphMargin": true,
  "editor.guides.indentation": true,
  "editor.lineHeight": 1.6,
  "editor.lineNumbers": "off",
  "editor.minimap.enabled": false,
  "editor.overviewRulerBorder": false,
  "editor.renderLineHighlight": "none",
  "editor.renderWhitespace": "none",
  "editor.rulers": [100],
  "editor.scrollbar.horizontal": "hidden",
  "editor.scrollbar.vertical": "hidden",
  "editor.stickyScroll.enabled": true,
  "editor.stickyScroll.scrollWithEditor": false,
  "editor.unicodeHighlight.ambiguousCharacters": false,
  "editor.unicodeHighlight.invisibleCharacters": false,
  "editor.wordWrap": "on",
  "editor.wordWrapColumn": 100,
  "editor.inlineSuggest.enabled": false,
  "editor.tabSize": 2,

  "errorLens.messageEnabled": true,
  "evenBetterToml.formatter.columnWidth": 100,
  "explorer.compactFolders": false,
  "explorer.confirmDragAndDrop": false,
  "extensions.ignoreRecommendations": true,
  "files.autoSave": "afterDelay",
  "files.insertFinalNewline": true,
  "gitlens.telemetry.enabled": false,
  "hediet.vscode-drawio.resizeImages": null,
  "isort.args": ["--profile", "black"],
  "isort.interpreter": [".venv/bin/python"],
  "java.format.settings.profile": "Google",
  "java.format.settings.url": "",
  "liveServer.settings.donotShowInfoMsg": true,
  "mdb.sendTelemetry": false,
  "notebook.codeActionsOnSave": {
    "notebook.source.organizeImports": "explicit"
  },
  "notebook.defaultFormatter": "ms-python.black-formatter",
  "notebook.formatOnSave.enabled": true,
  "path-intellisense.ignoreTsConfigBaseUrl": true,
  "settingsSync.ignoredExtensions": ["ms-vscode.powershell", "ms-vscode-remote.remote-wsl"],

  /** ------------ Terminal Configurations ------------ **/
  "terminal.external.osxExec": "WezTerm.app",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.enableImages": true,
  "terminal.integrated.enableMultiLinePasteWarning": "always",
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.fontFamily": "Symbols Nerd Font Mono",
  "terminal.integrated.gpuAcceleration": "on",
  "terminal.integrated.lineHeight": 1.3,
  "togglequotes.chars": ["\"", "'", "`"],
  "update.mode": "manual",
  "terminal.integrated.profiles.osx": {
    "tmux-shell": {
      "path": "tmux",
      "args": ["new-session", "-A", "-s", "vscode:${workspaceFolder}"]
    }
  },
  "terminal.integrated.defaultProfile.osx": "tmux-shell",

  /** ------------ VIM Configuration ------------ **/
  "vim.camelCaseMotion.enable": true,
  "vim.easymotion": true,
  "vim.leader": "<Space>",
  "vim.commandLineModeKeyBindingsNonRecursive": [],
  "vim.handleKeys": {
    "<C-u>": true
  },
  "vim.insertModeKeyBindingsNonRecursive": [{ "after": ["<ESC>"], "before": ["j", "k"] }],
  "vim.normalModeKeyBindingsNonRecursive": [
    { "before": ["u"], "commands": ["undo"] },
    // Explorer
    {
      "before": ["<leader>", "e", "e"],
      "commands": ["workbench.view.explorer"]
    },
    { "before": ["<leader>", "e", "f"], "commands": ["revealInExplorer"] },
    // Buffer
    { "before": ["]", "b"], "commands": [":bnext"] },
    { "before": ["[", "b"], "commands": [":bprevious"] },
    {
      "before": ["<leader>", "x"],
      "commands": ["workbench.action.closeActiveEditor"]
    },
    {
      "before": ["<leader>", "X"],
      "commands": ["workbench.action.closeOtherEditors"]
    },

    { "before": ["<leader>", "w"], "commands": ["workbench.action.file.save"] },
    { "after": [":"], "before": [";"] },
    {
      "before": ["<leader>", "t", "m"],
      "commands": ["workbench.action.selectTheme"]
    },
    { "before": ["<leader>", "/"], "commands": ["editor.action.commentLine"] },

    // Spliting editor and navigation
    {
      "before": ["<leader>", "s", "v"],
      "commands": ["workbench.action.splitEditorRight"]
    },
    {
      "before": ["<leader>", "s", "h"],
      "commands": ["workbench.action.splitEditorDown"]
    },
    {
      "before": ["<leader>", "s", "e"],
      "commands": ["workbench.action.evenEditorWidths"]
    },
    {
      "before": ["<leader>", "s", "x"],
      "commands": ["workbench.action.closeEditorsInGroup"]
    },
    {
      "before": ["<leader>", "h"],
      "commands": ["workbench.action.focusLeftGroup"]
    },
    {
      "before": ["<leader>", "j"],
      "commands": ["workbench.action.focusBelowGroup"]
    },
    {
      "before": ["<leader>", "k"],
      "commands": ["workbench.action.focusAboveGroup"]
    },
    {
      "before": ["<leader>", "l"],
      "commands": ["workbench.action.focusRightGroup"]
    },

    // Telescope like search
    {
      "before": ["<leader>", "f", "f"],
      "commands": ["workbench.action.quickOpen"]
    },
    {
      "before": ["<leader>", "f", "b"],
      "command": ["workbench.action.showAllEditors"]
    },
    {
      "before": ["<leader>", "f", "w"],
      "commands": ["workbench.action.findInFiles"]
    },
    {
      "before": ["<leader>", "t", "w"],
      "commands": ["workbench.actions.view.problems"]
    },
    {
      "before": ["<leader>", "t", "d"],
      "commands": ["workbench.actions.view.problems", "workbench.panel.markers.focus"]
    },

    // LSP
    {
      "before": ["<leader>", "g", "R"],
      "commands": ["editor.action.goToReferences"]
    },
    {
      "before": ["<leader>", "g", "D"],
      "commands": ["editor.action.goToDeclaration"]
    },
    {
      "before": ["<leader>", "g", "d"],
      "commands": ["editor.action.goToDefinition"]
    },
    {
      "before": ["<leader>", "g", "i"],
      "commands": ["editor.action.goToImplementation"]
    },
    {
      "before": ["<leader>", "g", "t"],
      "commands": ["editor.action.goToTypeDefinition"]
    },
    {
      "before": ["<leader>", "c", "a"],
      "commands": ["editor.action.quickFix"]
    },
    { "before": ["<leader>", "r", "n"], "commands": ["editor.action.rename"] },
    {
      "before": ["<leader>", "g", "h"],
      "commands": ["editor.action.showHover"]
    },
    { "before": ["K"], "commands": ["editor.action.triggerParameterHints"] },

    // Terminal
    {
      "before": ["<leader>", "t", "h"],
      "commands": ["workbench.action.terminal.toggleTerminal"]
    },
    {
      "before": ["<leader>", "t", "v"],
      "commands": ["workbench.action.terminal.toggleTerminal"]
    },

    // Emmet
    {
      "before": ["<leader>", "w", "e"],
      "commands": ["editor.emmet.action.wrapWithAbbreviation"]
    },

    // Git
    {
      "before": ["]", "h"],
      "commands": ["workbench.action.editor.nextChange"]
    },
    {
      "before": ["[", "h"],
      "commands": ["workbench.action.editor.previousChange"]
    },
    {
      "before": ["<leader>", "h", "s"],
      "commands": ["git.stageSelectedRanges"]
    },
    {
      "before": ["<leader>", "h", "u"],
      "commands": ["git.unstageSelectedRanges"]
    },
    {
      "before": ["<leader>", "h", "r"],
      "commands": ["git.revertSelectedRanges"]
    },
    { "before": ["<leader>", "h", "S"], "commands": ["git.stageAll"] },
    { "before": ["<leader>", "h", "R"], "commands": ["git.clean"] },
    {
      "before": ["<leader>", "h", "b"],
      "commands": ["gitlens.toggleLineBlame"]
    },
    {
      "before": ["<leader>", "h", "B"],
      "commands": ["gitlens.toggleFileBlame"]
    },
    { "before": ["<leader>", "h", "d"], "commands": ["git.openChange"] },
    {
      "before": ["<leader>", "h", "p"],
      "commands": [{ "command": "editor.action.dirtydiff.next", "args": [] }]
    },

    // Errors
    { "before": ["]", "d"], "commands": ["editor.action.marker.next"] },
    { "before": ["[", "d"], "commands": ["editor.action.marker.previous"] },
    {
      "before": ["<leader>", "d", "l"],
      "commands": ["editor.action.marker.next"]
    },

    // Zen mode
    {
      "before": ["<leader>", "z", "m"],
      "commands": ["workbench.action.toggleZenMode"]
    },

    // Command palette
    {
      "before": ["<leader>", "p", "p"],
      "commands": ["workbench.action.showCommands"]
    }
  ],
  "vim.smartRelativeLine": true,
  "vim.useCtrlKeys": false,
  "vim.useSystemClipboard": true,
  "vim.visualModeKeyBindingsNonRecursive": [
    {
      "before": ["<leader>", "/"],
      "commands": ["editor.action.commentLine"]
    },

    // indent lines and stay in visual
    { "before": ["<"], "commands": ["editor.action.outdentLines"] },
    { "before": [">"], "commands": ["editor.action.indentLines"] },

    // Emmet
    {
      "before": ["<leader>", "w", "e"],
      "commands": ["editor.emmet.action.wrapWithAbbreviation"]
    },

    // Git
    {
      "before": ["<leader>", "h", "s"],
      "commands": ["git.stageSelectedRanges"]
    },
    {
      "before": ["<leader>", "h", "r"],
      "commands": ["git.revertSelectedRanges"]
    },
    {
      "before": ["<leader>", "h", "u"],
      "commands": ["git.unstageSelectedRanges"]
    }
  ],

  /** ------------ Additional Configurations ------------ **/
  "vscode_custom_css.imports": [
    "file://${userHome}/.vscode/vscode-custom/style.css",
    "file://${userHome}/.vscode/extensions/brandonkirbyson.vscode-animations-2.0.7/dist/updateHandler.js"
  ],

  "window.titleBarStyle": "custom",

  /** ------------ Workbench Settings ------------ **/
  "workbench.colorCustomizations": {
    "statusBar.background": "#005f5f",
    "statusBar.debuggingBackground": "#005f5f",
    "statusBar.debuggingForeground": "#ffffff",
    "statusBar.foreground": "#ffffff",
    "statusBar.noFolderBackground": "#005f5f",
    "terminal.background": "#00000000"
  },
  "workbench.colorTheme": "Noir Catppuccin Mocha",
  "workbench.editor.editorActionsLocation": "titleBar",
  "workbench.editor.empty.hint": "hidden",
  "workbench.editorLargeFileConfirmation": 10024,
  "workbench.settings.applyToAllProfiles": ["workbench.colorCustomizations"],
  "workbench.startupEditor": "none",
  "workbench.tree.indent": 16,
  "workbench.editorAssociations": {
    "*.copilotmd": "vscode.markdown.preview.editor",
    "{git,gitlens,git-graph}:/**/*.{md,csv,svg}": "default",
    "*.md": "default",
    "*.markdown": "default",
    "*.csv": "gc-excelviewer-csv-editor"
  },

  "prettier.printWidth": 100,
  "terminal.integrated.env.osx": {},
  "gitlens.ai.model": "anthropic:claude-3-5-sonnet-latest",
  "markdown-preview-enhanced.previewColorScheme": "systemColorScheme",
  "markdown-preview-enhanced.previewTheme": "none.css",
  "markdown-preview-enhanced.codeBlockTheme": "vue.css",
  "workbench.layoutControl.enabled": false,
  "workbench.list.smoothScrolling": true,
  "editor.smoothScrolling": true,
  "terminal.integrated.smoothScrolling": true,
  "autoHide.mode": "auto",
  "workbench.productIconTheme": "feather-vscode"
}
